rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Product Images: anyone can read, only admin can upload/delete
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Blog Images: anyone can read, only admin can upload/delete
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Review Images: anyone can read, users can upload
    match /reviews/{allPaths=**} {
      allow read: if true;
      allow create: if isAuthenticated() 
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin() || isAuthenticated();
    }
    
    // User Profile Images: users can read/write their own
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId
                  && request.resource.size < 2 * 1024 * 1024 // Max 2MB
                  && request.resource.contentType.matches('image/.*');
    }

    // Invoices: users can read their own, admin can read/write
    match /invoices/{userId}/{allPaths=**} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAdmin();
    }
  }
}
